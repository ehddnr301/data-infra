# ── Cloudflare 인증 ──────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ── R2 (S3 호환 API) ────────────────────────────
# endpoint: https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── D1 (HTTP API) ───────────────────────────────
D1_DATABASE_ID=

# ── Slack 알림 (선택) ──────────────────────────────
SLACK_WEBHOOK_URL=

# ── Discord 수집 ────────────────────────────────
DISCORD_USER_TOKEN=

# ── 도메인별 토큰/세부 설정 ───────────────────────
# GitHub/Discord ingestion CLI는 각 도메인 config.yaml 인접 .env도 함께 읽습니다.
# 아래 파일을 별도로 채워 두세요.
#   - domains/github/ingestion/.env
#   - domains/discord/ingestion/.env
