# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
OPENCLAW_ANTHROPIC_TIMEOUT_SECONDS=30
OPENCLAW_ANTHROPIC_MAX_RETRIES=2
OPENCLAW_ANTHROPIC_MAX_TOKENS=1024
OPENCLAW_PLANNER_PROMPT_MAX_COLUMNS=80
OPENCLAW_PLANNER_FALLBACK_MAX_COLUMNS=30

# Catalog API
CATALOG_API_BASE_URL=http://127.0.0.1:8787
CATALOG_INTERNAL_BEARER=

# OpenClaw guardrails
OPENCLAW_RUN_MODE=dry-run
OPENCLAW_WRITE_ENABLED=false
OPENCLAW_APPROVAL_TTL_SECONDS=300

# Retry policy
OPENCLAW_MAX_RETRY_ATTEMPTS=3
OPENCLAW_RETRY_BACKOFF_MS=1000

# Runtime
OPENCLAW_APP_VERSION=0.1.0
