{
  "display_information": {
    "name": "PseudoLab Clawbot",
    "description": "AI-powered catalog quality bot for PseudoLab",
    "background_color": "#1f2937"
  },
  "features": {
    "bot_user": {
      "display_name": "clawbot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/clawbot",
        "url": "https://bearbot.win/slack/command",
        "description": "Generate and apply catalog enrichment plans",
        "usage_hint": "plan \"seed text\"",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": ["chat:write", "chat:write.public", "commands", "channels:history"]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://bearbot.win/slack/interactive"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
